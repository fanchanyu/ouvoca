# =========================================================================
# LLM-ERP backend configuration
# Copy this file to `.env` and adjust values for your environment.
# =========================================================================

# --- app ---
APP_NAME=LLM-ERP
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false

# --- database ---
# Dev (default): SQLite. Prod: switch DATABASE_DRIVER=postgresql and set DATABASE_URL_PROD.
DATABASE_DRIVER=sqlite
DATABASE_URL=sqlite+aiosqlite:///./erp.db
DATABASE_URL_PROD=postgresql+asyncpg://erp:erp@postgres:5432/erp
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# --- auth ---
# Generate a strong secret in production: `openssl rand -hex 32`
JWT_SECRET=change-me-in-production-please-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
# When JWT_SECRET is the default, the auth middleware accepts Bearer "demo" as a super-admin.
# Auto-disables once you set a real JWT_SECRET — so production is safe.
ALLOW_DEMO_BYPASS=true

# --- LLM ---
# Provider options: deepseek | openai | anthropic | ollama
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MAX_TOOL_ROUNDS=5
LLM_TIMEOUT_SECONDS=60
OLLAMA_BASE_URL=http://localhost:11434

# --- MESH / Multi-factory ---
FACTORY_MODE=hq
FACTORY_ID=hq
# JSON-style list for multiple nodes
FACTORY_NODES=["http://factory-a:8001","http://factory-b:8002","http://factory-c:8003"]
MESH_TIMEOUT_SECONDS=5

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8080"]

# --- middleware ---
EVENT_SSE_ENABLED=true
AUDIT_LOG_ENABLED=true

# --- seed ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
