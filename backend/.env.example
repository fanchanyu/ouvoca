# ============================================================
#  Ouvoca ERP — 環境變數範本
#  使用方式：複製此檔案為 .env，填入必要的值後啟動服務
#  Usage: Copy this file to .env, fill required values, then start services
# ============================================================

# ─── 應用程式基本 / App ──────────────────────────────────────
APP_NAME=Ouvoca ERP
# 應用程式版本號（通常不需修改）
APP_VERSION=2.0.0
# 開發模式；正式部署改為 false
DEBUG=true

# ─── 日誌 / Logging ──────────────────────────────────────────
# 日誌等級：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# true 輸出 JSON 格式 log，適合 ELK/CloudWatch
LOG_JSON=false

# ─── 資料庫 / Database ───────────────────────────────────────
# 開發用 sqlite；正式部署改 postgresql
DATABASE_DRIVER=sqlite
# SQLite 路徑，相對於 backend/ 目錄
DATABASE_URL=sqlite+aiosqlite:///./erp.db
# PostgreSQL 連線字串，如 postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL_PROD=
# PostgreSQL 連線池大小（DATABASE_DRIVER=postgresql 時生效）
DB_POOL_SIZE=20
# 超出 pool 時允許額外連線數上限
DB_MAX_OVERFLOW=10

# ─── 認證 / Auth ─────────────────────────────────────────────
# 必填！執行 openssl rand -hex 32 生成，最少 32 字元
JWT_SECRET=change-me-in-production-please-use-openssl-rand-hex-32
# JWT 加密演算法（不建議更改）
JWT_ALGORITHM=HS256
# JWT Token 有效分鐘數（預設 8 小時）
JWT_EXPIRE_MINUTES=480
# 警告：true 時 Bearer demo 可取得超級管理員權限，僅限測試
ALLOW_DEMO_BYPASS=false

# ─── LLM 設定 / LLM Settings ─────────────────────────────────
# 選項：openai / deepseek / anthropic / ollama
LLM_PROVIDER=deepseek
# deepseek-chat / gpt-4o / claude-3-5-sonnet / llama3
LLM_MODEL=deepseek-chat
# 對應供應商的 API Key
LLM_API_KEY=
# LLM API 基底 URL（deepseek 預設值，切換 provider 時需更改）
LLM_BASE_URL=https://api.deepseek.com/v1
# LLM 最多呼叫幾輪 tool（避免無限迴圈）
LLM_MAX_TOOL_ROUNDS=5
# LLM API 請求逾時秒數
LLM_TIMEOUT_SECONDS=60
# Windows dev 環境若 CA store 失效可設 false
LLM_VERIFY_SSL=true

# ─── 各供應商專用 API Key ────────────────────────────────────
# OpenAI 專用，LLM_PROVIDER=openai 時填入
OPENAI_API_KEY=
# Anthropic 專用
ANTHROPIC_API_KEY=
# DeepSeek 專用
DEEPSEEK_API_KEY=
# Ollama 本地端點（LLM_PROVIDER=ollama 時使用）
OLLAMA_BASE_URL=http://localhost:11434

# ─── MESH 多廠 / Factory MESH ────────────────────────────────
# 本節點身份：hq（總部）或 factory（分廠）
FACTORY_MODE=hq
# 本節點 ID（hq 或各分廠唯一名稱）
FACTORY_ID=hq
# MESH 多廠節點，逗號分隔，如 http://factory-a:8001,http://factory-b:8002
FACTORY_NODES=
# MESH 節點間請求逾時秒數
MESH_TIMEOUT_SECONDS=5

# ─── 中介層 / Middleware ─────────────────────────────────────
# 允許的前端來源（逗號分隔 URL 列表）
# 注意：Windows 上 localhost 可能解析為 IPv6 ::1，建議同時列 127.0.0.1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000
# 啟用 SSE 事件串流（即時通知）
EVENT_SSE_ENABLED=true
# 啟用操作稽核日誌
AUDIT_LOG_ENABLED=true

# ─── 初始資料 / Seed ─────────────────────────────────────────
# 系統初始化時建立的管理員帳號
SEED_ADMIN_USERNAME=admin
# 系統初始化時建立的管理員密碼（上線後請立即修改）
SEED_ADMIN_PASSWORD=admin123

# ─── AI 用量限制 / AI Quota ──────────────────────────────────
# 每人每日最多呼叫 LLM 的次數上限
AI_DAILY_LIMIT_PER_USER=200
