# ════════════════════════════════════════════════════════════
# Ouvoca · .gitignore
# 規則優先級：securityrisk > buildartifact > localcache
# ════════════════════════════════════════════════════════════

# ─── 🚨 SECRETS（絕對不可推）───────────────────────────────
.env
.env.*
!.env.example
!.env.template

# ─── 使用者上傳檔案（Sprint E v3.13）────────────────────────
# 不可推 — 可能含使用者業務敏感資料（報價單 / 發票 / 合約）
# 寫 backend/uploads/* 不是 backend/uploads/ 才能讓 !.gitkeep 例外生效
backend/uploads/*
!backend/uploads/.gitkeep
# v3.53: 部分 test 從根目錄起跑 → uploads/ 會建在 repo root（test 殘留）
uploads/
!uploads/.gitkeep
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
secrets/
**/credentials.json
**/service-account*.json
# GitHub tokens / API keys / Slack — 即使檔名前綴也擋
gho_*
ghp_*
sk-*
xoxb-*
# WireGuard 私鑰
wg0.conf
privatekey
# .env-style files everywhere
*/backend/.env
*/frontend/.env
*/frontend-desktop/.env
# (frontend-mobile/ removed in v3.0 — desktop-only DNA)

# ─── 💾 資料庫 / 持久化（不可推）─────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
erp.db*
factory_*.db
# PostgreSQL backup
*.sql.gz
/backup/
/opt/backup/

# ─── 🐍 Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# 移除 lib/ — 太廣，會誤殺 frontend-desktop/src/lib/
# Python venv 的 lib 已被 venv/ .venv/ 規則擋掉
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 虛擬環境
.env/
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/
.pyenv

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# mypy / ruff
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# ─── 🟦 Node.js / 前端 ───────────────────────────────────
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
# 各機器自行 lock，避免衝突
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build output
dist/
build/
.next/
out/
.nuxt/
.cache/
.parcel-cache/
.vite/
*.local

# ─── 🐳 Docker ───────────────────────────────────────────
.docker/

# ─── 📄 PDF 文件（v3.13 起入版控，讓 GitHub 訪客直接下載）──
# 35 份雙語客戶手冊是商業價值的一部分，必須在 GitHub 看得到。
# build_pdfs 重生後手動 commit + push 更新

# 但 SVG 是手繪資產，留住
!docs/*.svg

# ─── 🛠 IDE / Editor ─────────────────────────────────────
.idea/
.vscode/
!.vscode/settings.example.json
!.vscode/extensions.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ─── 📊 Log ──────────────────────────────────────────────
*.log
logs/
/var/log/llm-erp/

# ─── 🔁 暫存 / 平台 ──────────────────────────────────────
*.tmp
*.bak
*.orig
.~lock.*
*.lnk

# ─── 🧪 演練資料 / 測試產生物 ────────────────────────────
test-results/
playwright-report/
# ─── 🔐 內部專案文件（暫不公開的）────────────────────────
# 若這些文件之後決定公開，移除對應行即可
# docs/PRICING_INTERNAL.md
# docs/REVENUE_PROJECTION.md

# ─── 🤖 內部 AI 工作檔（v3.25.3 私有化）───────────────────
# CLAUDE.md：AI 會話啟動讀的「北極星」總控檔（內部進度看板）
# docs/WORKLOG.md：動態工作日誌（每次會話末尾追加）
# 這兩份是 AI 協作的長期記憶，不是給客戶/貢獻者看的對外文件。
# 對外請看 docs/ROADMAP.md / docs/ARCHITECTURE_DECISIONS.md。
CLAUDE.md
docs/WORKLOG.md

# ─── 📦 PDF 中間檔（mermaid 暫存）────────────────────────
scripts/build-pdfs/.tmp/
**/llm-erp-mermaid-*/

# ─── 大檔案（避免誤推）───────────────────────────────────
*.iso
*.zip
*.tar.gz
*.7z
*.rar
*.dmg
*.exe
*.msi

# ─── install_easy.bat 下載的工具（不可推）─────────────────
# 內含 Python embedded (~250MB) + Node embedded (~70MB)
# 重新安裝會自動下載；提交會讓 repo 暴漲
tools/

# install_easy 產生的執行期檔案
.backend.pid
.frontend.pid
logs-backend.txt
logs-frontend.txt
backend/.seeded

# update.bat 產生的備份目錄（含使用者業務資料，絕對不可推）
backups/
