{
  "expo": {
    "name": "LLM-ERP",
    "slug": "llm-erp-mobile",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "llm-erp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.llmerp.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.llmerp.mobile",
      "permissions": [
        "CAMERA",
        "NOTIFICATIONS",
        "INTERNET",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "允許 LLM-ERP 使用相機掃描 QR Code / Allow LLM-ERP to use camera for QR scanning"
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:8000"
    }
  }
}
