#!/bin/sh
# ============================================================
#  Ouvoca · pre-push hook — push 前強制跑 8 道 gate
# ============================================================
#  替代 GitHub branch protection（免費 private 不支援）
#  跳過：git push --no-verify（**不建議**）
#  快速通道：git push -o ci.skip=true（**僅限文件 only 變更**）
# ============================================================

set -e

# ANSI 顏色
if [ -t 1 ]; then
    R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'; B='\033[0;34m'; N='\033[0m'
else
    R=''; G=''; Y=''; B=''; N=''
fi

REPO=$(git rev-parse --show-toplevel)
cd "$REPO"

# 只在推 main / develop 時跑 — feature branch 開發階段不擋
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "?")
if [ "$BRANCH" != "main" ] && [ "$BRANCH" != "develop" ]; then
    exit 0
fi

# 已 push 過的 commit 不重跑（看 .git/refs/remotes/origin/main vs HEAD）
LOCAL=$(git rev-parse HEAD 2>/dev/null || echo "?")
REMOTE=$(git rev-parse "origin/$BRANCH" 2>/dev/null || echo "?")
if [ "$LOCAL" = "$REMOTE" ]; then
    printf "${Y}(no new commits to push, skipping gates)${N}\n"
    exit 0
fi

# 快速通道：只改 .md / docs/ 不跑 gate
CHANGED=$(git diff --name-only "$REMOTE..HEAD" 2>/dev/null || echo "")
ONLY_DOCS=true
if [ -n "$CHANGED" ]; then
    for f in $CHANGED; do
        case "$f" in
            *.md|docs/*|*.svg) ;;
            *) ONLY_DOCS=false; break ;;
        esac
    done
fi
if [ "$ONLY_DOCS" = "true" ] && [ -n "$CHANGED" ]; then
    printf "${G}(docs/md only — gates skipped)${N}\n"
    exit 0
fi

printf "${B}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${N}\n"
printf "${B}🛡  pre-push: 跑 8 道 gate（推到 $BRANCH 前必過）${N}\n"
printf "${B}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${N}\n"

if [ ! -x scripts/run_gates.sh ]; then
    printf "${R}❌ scripts/run_gates.sh 不存在或無執行權限${N}\n"
    exit 1
fi

# 跑 gates，失敗直接擋 push
if ! bash scripts/run_gates.sh; then
    printf "\n${R}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${N}\n"
    printf "${R}🚫 Push 被擋：gate 有紅燈。修好再 push。${N}\n"
    printf "${R}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${N}\n"
    printf "${Y}緊急狀況跳過（不建議）：git push --no-verify${N}\n"
    exit 1
fi

printf "${G}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${N}\n"
printf "${G}🟢 pre-push: gates 全綠，允許 push${N}\n"
printf "${G}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${N}\n"
exit 0
