#!/bin/sh
# ============================================================
#  erpilot · pre-commit hook
#  防止 API key / token / private key 被誤推
# ============================================================
#  跳過：commit 時加 --no-verify（**不建議**，會繞過所有檢查）
# ============================================================

set -e

# ANSI 顏色（terminal 支援時才會顏色化）
if [ -t 1 ]; then
    R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'; B='\033[0;34m'; N='\033[0m'
else
    R=''; G=''; Y=''; B=''; N=''
fi

FAIL=0

# 只掃將被 commit 的內容（git diff --cached）
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED" ]; then
    exit 0
fi

# ─── 規則 1：高熵 sk- / ghp_ / gho_ / xoxb- secret pattern ──
PATTERNS=$(cat <<'EOF'
sk-[a-zA-Z0-9_-]{30,}
sk-proj-[a-zA-Z0-9_-]{20,}
sk-ant-api[0-9]{2}-[a-zA-Z0-9_-]{20,}
ghp_[a-zA-Z0-9]{30,}
gho_[a-zA-Z0-9]{30,}
ghs_[a-zA-Z0-9]{30,}
github_pat_[a-zA-Z0-9_]{40,}
xoxb-[0-9]+-[0-9]+-[a-zA-Z0-9]+
AKIA[0-9A-Z]{16}
AIza[0-9A-Za-z_-]{35}
ya29\.[0-9A-Za-z_-]+
EOF
)

# 用 -E 多 pattern 一次掃
PATTERN_RE=$(echo "$PATTERNS" | tr '\n' '|' | sed 's/|$//')

HITS=$(git diff --cached -U0 | grep -E "^\+" | grep -EHn "$PATTERN_RE" 2>/dev/null || true)
if [ -n "$HITS" ]; then
    printf "${R}🚨 BLOCKED: 偵測到疑似 API key / token：${N}\n"
    echo "$HITS" | head -10 | sed 's/^/  /'
    printf "${Y}修法：移除該 secret 後 git add + git commit 重來。${N}\n"
    printf "${Y}若是測試假資料，請改成 'sk-test-FAKE-DO-NOT-USE'。${N}\n"
    FAIL=1
fi

# ─── 規則 2：禁止推 .env / private key / DB ────────────────
BAD_FILES=$(echo "$STAGED" | grep -E '(^|/)\.env($|\.)|\.key$|\.pem$|\.p12$|\.pfx$|\.db$|\.sqlite[0-9]?$' | grep -v -E '\.env\.example$|\.env\.template$' || true)
if [ -n "$BAD_FILES" ]; then
    printf "${R}🚨 BLOCKED: 不可推這些檔案：${N}\n"
    echo "$BAD_FILES" | sed 's/^/  /'
    printf "${Y}修法：${N}\n"
    printf "  git rm --cached <file>\n"
    printf "  加入 .gitignore\n"
    FAIL=1
fi

# ─── 規則 3：JWT_SECRET / POSTGRES_PASSWORD 寫死成非 placeholder ─
HARDCODED=$(git diff --cached -U0 | grep -E "^\+" | grep -E 'JWT_SECRET\s*=\s*["'\'']?[a-zA-Z0-9]{32,}|POSTGRES_PASSWORD\s*=\s*["'\'']?[a-zA-Z0-9!@#$%^&*()_+=-]{16,}' | grep -v -E 'change-me|placeholder|example|test-jwt|x{20,}|\$\{|\${' || true)
if [ -n "$HARDCODED" ]; then
    printf "${R}🚨 BLOCKED: 偵測到 hardcoded JWT_SECRET / POSTGRES_PASSWORD：${N}\n"
    echo "$HARDCODED" | head -5 | sed 's/^/  /'
    printf "${Y}修法：改用 \${ENV_VAR} 形式從 .env 讀取。${N}\n"
    FAIL=1
fi

# ─── 規則 4：node_modules / __pycache__ / .venv 被誤加 ────
BAD_DIR=$(echo "$STAGED" | grep -E '(^|/)(node_modules|__pycache__|\.venv|venv|\.pytest_cache|\.mypy_cache|\.next|dist|build)/' | head -3 || true)
if [ -n "$BAD_DIR" ]; then
    printf "${R}🚨 BLOCKED: 偵測到 build / 快取目錄被加：${N}\n"
    echo "$BAD_DIR" | sed 's/^/  /'
    printf "${Y}修法：git rm --cached -r <dir> + 確認 .gitignore${N}\n"
    FAIL=1
fi

if [ $FAIL -ne 0 ]; then
    printf "\n${R}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${N}\n"
    printf "${R}Commit 被擋下。修好上述問題再重試。${N}\n"
    printf "${R}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${N}\n"
    exit 1
fi

printf "${G}✓ pre-commit 安全檢查通過${N}\n"
exit 0
